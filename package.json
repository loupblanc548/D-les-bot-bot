{
  "name": "discord-surveillance-bot",
  "version": "1.0.0",
  "description": "Bot Discord de surveillance des reseaux sociaux, moderation et gaming",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx --inspect src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "register": "tsx src/index.ts --register",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "cli": "tsx scripts/cli.ts"
  },
  "dependencies": {
    "@bull-board/api": "^8.0.1",
    "@bull-board/express": "^8.0.1",
    "@discordjs/voice": "^0.19.2",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.57.0",
    "@types/express": "^5.0.6",
    "axios": "^1.17.0",
    "bullmq": "^5.79.0",
    "cheerio": "^1.2.0",
    "compromise": "^14.15.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.8.0",
    "ffmpeg-static": "^5.3.0",
    "ioredis": "^5.11.1",
    "libsodium-wrappers": "^0.8.4",
    "ms": "^2.1.3",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "play-dl": "^1.9.7",
    "playwright": "^1.60.0",
    "prism-media": "^1.3.5",
    "prom-client": "^15.1.3",
    "psn-api": "2.18.0",
    "redis": "^6.0.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.35.2",
    "undici": "^8.5.0",
    "winston": "^3.19.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.9.4",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-security": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prisma": "^5.22.0",
    "semgrep": "^0.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "undici": "^8.5.0"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true
  }
}
