{
  "version": "0.2",
  "language": "en,fr",
  "allowCompoundWords": true,
  "enabledFileTypes": {
    "json": false,
    "jsonc": false,
    "log": false,
    "plaintext": false,
    "markdown": false
  },
  "ignorePaths": [
    "node_modules/**",
    "dist/**",
    "coverage/**",
    "logs/**",
    "backups/**",
    "_dump/**",
    ".kilocode/**",
    ".agent-cache/**",
    "package-lock.json",
    "*.log",
    "*.tsbuildinfo",
    "*.json",
    "parse.js",
    "erreur.txt",
    "errors-list.txt",
    "unused-*.txt",
    "tsc_*.txt",
    "eslint*.json",
    "eslint*.std*",
    "*.cjs"
  ],
  "words": [
    "RAWG",
    "Akamai",
    "steamstatic",
    "discordjs",
    "ioredis",
    "bullmq",
    "neondb",
    "neon",
    "openrouter",
    "helldiver",
    "fortnite",
    "psn",
    "xbox",
    "twitch",
    "rss",
    "tsx",
    "vitest",
    "prismjs",
    "dedup",
    "dedupe",
    "upsert",
    "cooldown",
    "favicon",
    "webhook",
    "webhooks"
  ]
}
