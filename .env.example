# ═══════════════════════════════════════════════════════════════════════════════
#  Discord Surveillance Bot - Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_TOKEN="votre_token_discord"
DISCORD_CLIENT_ID="votre_client_id"
DISCORD_GUILD_ID="votre_guild_id"
OWNER_ID="votre_user_id"

# ── OpenRouter AI ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY="votre_cle_api"
OPENROUTER_MODEL="openai/gpt-4o"
AI_SYSTEM_PROMPT="Tu es un assistant utile et concis. Reponds en francais."

# ── APIs Externes ──────────────────────────────────────────────────────────────
ISTHEREANYDEAL_API_KEY="votre_cle_api"
TWITCH_CLIENT_ID="votre_client_id"
TWITCH_CLIENT_SECRET="votre_client_secret"
TWITCH_ACCESS_TOKEN="votre_access_token"
STEAM_API_KEY="votre_cle_api"
PSN_NPSSO_TOKEN="votre_token_npsso"

# ── Nouvelles APIs (laisser vide si non configuré — fallback gracieux) ─────────
PERSPECTIVE_API_KEY=""              # Google Perspective (toxicité IA)
GIPHY_API_KEY=""                     # GIPHY API (GIFs)
YOUTUBE_API_KEY=""                  # YouTube Data API v3
SPOTIFY_CLIENT_ID=""                # Spotify Web API
SPOTIFY_CLIENT_SECRET=""            # Spotify Web API
RAWG_API_KEY=""                     # RAWG (base de données jeux)
NEWS_API_KEY=""                     # NewsAPI (articles gaming)
SCREENSHOT_API_KEY=""               # ScreenshotOne (capture URL)
HF_API_KEY=""                       # Hugging Face Inference
LASTFM_API_KEY=""                   # Last.fm API
# Anti-phishing : Sinking Yachts (sans clé) + Google Safe Browsing (utilise PERSPECTIVE_API_KEY)
IMGUR_CLIENT_ID=""                  # Imgur API (upload images)
REDDIT_CLIENT_ID=""                 # Reddit API officielle
REDDIT_CLIENT_SECRET=""             # Reddit API officielle
REDDIT_USER_AGENT=""                # User-Agent Reddit (ex: bot:myapp:v1.0)

# ── Twitter/X (xcancel.com) ────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN="votre_bearer_token"

# ── Bluesky ────────────────────────────────────────────────────────────────────
BLUESKY_IDENTIFIER="votre_identifiant"
BLUESKY_APP_PASSWORD="votre_app_password"

# ── Base de donnees ────────────────────────────────────────────────────────────
# PostgreSQL (production / Docker) :
DATABASE_URL="postgresql://discord_bot:discord_bot@postgres:5432/discord_bot?schema=public"
# SQLite (developpement local) :
# ⚠️  Pour SQLite, changer le provider dans prisma/schema.prisma :
#     datasource db { provider = "sqlite" ... }
# DATABASE_URL="file:./database.sqlite"

# ── PostgreSQL Options ─────────────────────────────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# Pooling (recommande en prod) — Neon : utiliser l'endpoint -pooler + connection_limit :
# DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require&connection_limit=15&pool_timeout=10"

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ── Salons Discord (Channel Routing) ───────────────────────────────────────────
STEAM_EPIC_CHANNEL_ID="votre_channel_id"
STEAM_NEWS_CHANNEL_ID="votre_channel_id"
PLAYSTATION_CHANNEL_ID="votre_channel_id"
FORTNITE_CHANNEL_ID="votre_channel_id"
XBOX_CHANNEL_ID="votre_channel_id"
NINTENDO_CHANNEL_ID="votre_channel_id"
INSTANT_GAMING_CHANNEL_ID="votre_channel_id"
FREE_GAMES_CHANNEL_ID="votre_channel_id"
EPIC_GAMES_CHANNEL_ID="1504932229795549385"
LOG_CHANNEL_ID="votre_channel_id"
DEDICATED_CHANNEL_ID="votre_channel_id"
DEALS_CHANNEL_ID="votre_channel_id"
PRICE_TRACK_CHANNEL_ID="votre_channel_id"
TRENDS_CHANNEL_ID="votre_channel_id"
VIRAL_CHANNEL_ID="votre_channel_id"

# ── Roles ──────────────────────────────────────────────────────────────────────
ADMIN_ROLES=""
FREE_GAMES_ROLE_ID=""

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS="5"
RATE_LIMIT_MAX_REQUESTS="3"

# ── Control Panel ──────────────────────────────────────────────────────────────
CONTROL_PORT="3000"
CONTROL_TOKEN="votre_token_secret"

# ── Monitoring (Sentry) ────────────────────────────────────────────────────────
SENTRY_DSN="votre_dsn_sentry"

# ── Crash Webhook (alertes critiques si le bot crash) ──────────────────────────
CRASH_WEBHOOK_URL=""

# ── Bull Board (dashboard visuel des queues) ───────────────────────────────────
BULL_BOARD_PORT="3006"

# Neon direct connection URL (non-pooled, pour migrations Prisma)
DIRECT_URL=postgresql://owner:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
